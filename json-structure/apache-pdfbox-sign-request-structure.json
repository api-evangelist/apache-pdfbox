{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/apache-pdfbox/refs/heads/main/json-structure/apache-pdfbox-sign-request-structure.json",
  "description": "SignRequest schema from Apache PDFBox",
  "type": "object",
  "properties": {
    "keystorePath": {
      "type": "string",
      "example": "keystore.p12"
    },
    "password": {
      "type": "string",
      "example": "keystore-password"
    },
    "reason": {
      "type": "string",
      "example": "Document approval"
    },
    "location": {
      "type": "string",
      "example": "San Francisco, CA"
    }
  },
  "name": "SignRequest"
}