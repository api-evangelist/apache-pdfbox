{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/apache-pdfbox/refs/heads/main/json-schema/apache-pdfbox-page-list-schema.json",
  "title": "PageList",
  "description": "PageList schema from Apache PDFBox",
  "type": "object",
  "properties": {
    "documentId": {
      "type": "string",
      "example": "doc-abc123"
    },
    "totalPages": {
      "type": "integer",
      "example": 10
    },
    "pages": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/PageInfo"
      }
    }
  }
}